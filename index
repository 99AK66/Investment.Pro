</div>

<!-- ═══ TAB 2: Portfolio ═══ -->
<div id="tab-portfolio" class="tab-content">
  <div id="portfolio-summary" style="display:none" class="panel fadeUp">
    <div class="result-grid">
      <div style="text-align:center"><div class="label">พอร์ตรวม</div><div id="pt-total" style="font-family:'DM Mono',monospace;font-size:12px;font-weight:800;color:#f59e0b"></div></div>
      <div style="text-align:center"><div class="label">ลงทุนไป</div><div id="pt-invested" style="font-family:'DM Mono',monospace;font-size:12px;font-weight:800;color:#94a3b8"></div></div>
      <div style="text-align:center"><div class="label">กำไร/ขาดทุน</div><div id="pt-gain" style="font-family:'DM Mono',monospace;font-size:12px;font-weight:800"></div></div>
    </div>
  </div>
  <div id="portfolio-donut-wrap" style="display:none;margin-top:12px;"></div>
  <div id="portfolio-assets" style="margin-top:4px;"></div>
  <button class="btn-dashed" onclick="addPortfolioAsset()">+ เพิ่มทรัพย์สิน</button>
</div>

<!-- ═══ TAB 3: Multi DCA ═══ -->
<div id="tab-multi" class="tab-content">
  <div class="panel" style="padding:16px;">
    <div class="grid-2">
      <div><div class="label">DCA ต่อเดือน (฿)</div><input class="inp" id="m-monthly" type="number" placeholder="10000" oninput="updateMulti()"></div>
      <div><div class="label">ระยะเวลา (ปี)</div><input class="inp" id="m-years" type="number" placeholder="30" oninput="updateMulti()"></div>
    </div>
  </div>

  <div class="panel" style="margin-top:12px;">
    <div class="multi-header">
      <div class="panel-title" style="margin-bottom:0">ASSETS</div>
      <div style="display:flex;gap:8px">
        <button class="btn-auto" onclick="autoBalance()">⚖️ Auto</button>
        <button class="btn-add" onclick="addMultiAsset()">+ เพิ่ม</button>
      </div>
    </div>
    <div class="asset-cols-header">
      <span></span><span>ชื่อหุ้น</span><span style="text-align:center">CAGR %</span><span style="text-align:center">สัดส่วน</span><span></span>
    </div>
    <div id="multi-asset-rows"></div>
    <div id="alloc-donut-wrap" class="alloc-panel" style="margin-top:12px;"></div>
  </div>

  <div id="multi-prompt" style="text-align:center;padding:28px 0;color:#334155;font-size:13px;font-family:'DM Mono',monospace;">← กรอก DCA/เดือน และระยะเวลาก่อน</div>
  <div id="multi-alloc-warn" class="warning" style="display:none">⚠️ สัดส่วนรวม <span id="warn-alloc"></span>% — ต้องรวมได้ 100%</div>

  <div id="multi-results" style="display:none">
    <div class="summary-hero">
      <div>
        <div style="font-size:10px;color:#f59e0b;font-family:'DM Mono',monospace;letter-spacing:1px">🏆 พอร์ตรวมใน <span id="hero-years"></span> ปี</div>
        <div id="hero-final" style="font-size:24px;font-weight:800;color:#fff;margin-top:4px"></div>
        <div id="hero-final-full" style="font-size:11px;color:#64748b;margin-top:2px;font-family:'DM Mono',monospace"></div>
      </div>
      <div style="text-align:right">
        <div style="font-size:11px;color:#64748b;font-family:'DM Mono',monospace">ลงทุนไป</div>
        <div id="hero-invested" style="font-size:15px;font-weight:700;color:#94a3b8"></div>
        <div id="hero-mult" style="font-size:13px;color:#22c55e;margin-top:4px;font-weight:700"></div>
      </div>
    </div>
    <div class="asset-mini-grid" id="asset-mini-cards"></div>

    <div class="sub-tabs">
      <button class="sub-tab-btn active" onclick="switchSubTab('chart',this)">📈 กราฟ</button>
      <button class="sub-tab-btn" onclick="switchSubTab('table',this)">📊 ตาราง</button>
      <button class="sub-tab-btn" onclick="switchSubTab('milestone',this)">🏁 Milestone</button>
    </div>
    <div id="subtab-chart" class="sub-tab-content active">
      <div class="chart-wrap"><canvas id="lineChart"></canvas>
        <div id="chart-legend" style="display:flex;flex-wrap:wrap;gap:8px;padding:6px 10px 0;justify-content:center;"></div>
      </div>
    </div>
    <div id="subtab-table" class="sub-tab-content">
      <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:14px;margin-top:10px;overflow-x:auto">
        <table class="data-table" id="data-table"></table>
      </div>
    </div>
    <div id="subtab-milestone" class="sub-tab-content">
      <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:14px;margin-top:10px;overflow:hidden">
        <div id="milestone-content"></div>
      </div>
    </div>
  </div>
</div>

<div class="footer-note">* การลงทุนมีความเสี่ยง ผลตอบแทนในอดีตไม่ได้รับประกันอนาคต · ไม่ใช่คำแนะนำการลงทุน</div>

<script>
// ─── Constants ───
const COLORS = ["#f59e0b","#22c55e","#3b82f6","#a78bfa","#f43f5e","#06b6d4","#fb923c","#84cc16","#e879f9","#38bdf8"];

// ─── Formatters ───
function fBaht(v){if(v>=1e9)return`฿${(v/1e9).toFixed(2)}B`;if(v>=1e6)return`฿${(v/1e6).toFixed(2)}M`;if(v>=1e3)return`฿${(v/1e3).toFixed(1)}K`;return`฿${Math.round(v)}`;}
function fFull(v){return`฿${Math.round(v).toLocaleString('th-TH')}`;}
function fNum(n){return n.toLocaleString('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2});}

// ─── Tab switcher ───
function switchTab(id, btn){
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}
function switchSubTab(id, btn){
  document.querySelectorAll('.sub-tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.sub-tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('subtab-'+id).classList.add('active');
  btn.classList.add('active');
}

// ─── DCA Math ───
function calcDCA(monthly, years, annualRate){
  const r = annualRate/100/12;
  let portfolio = 0;
  const data = [];
  for(let m=1;m<=years*12;m++){
    portfolio = (portfolio+monthly)*(1+r);
    if(m%12===0) data.push({year:m/12,portfolio:Math.round(portfolio),invested:monthly*m});
  }
  return data;
}

// ═══ TAB 1: Simple DCA ═══
function calcSimple(){
  const name = document.getElementById('s-name').value;
  const monthly = parseFloat(document.getElementById('s-monthly').value);
  const months = parseInt(document.getElementById('s-months').value);
  const growth = parseFloat(document.getElementById('s-growth').value)/100/12;
  if(!monthly||!months) return;
  let total=0;
  const rows=[];
  for(let i=1;i<=months;i++){
    total = growth>0?total*(1+growth)+monthly:total+monthly;
    if(i%Math.max(1,Math.floor(months/12))===0||i===months) rows.push({month:i,total});
  }
  const invested=monthly*months;
  const gain=total-invested;
  document.getElementById('s-asset-name').textContent=name||'ทรัพย์สิน';
  document.getElementById('s-invested').textContent=`฿${fNum(invested)}`;
  document.getElementById('s-final').textContent=`฿${fNum(total)}`;
  const gainEl=document.getElementById('s-gain');
  gainEl.textContent=`${gain>=0?'+':''}฿${fNum(gain)}`;
  gainEl.style.color=gain>=0?'#22c55e':'#f43f5e';
  document.getElementById('s-month-end').textContent=`เดือน ${months}`;
  // Mini bars
  const barsEl=document.getElementById('s-bars');
  barsEl.innerHTML='';
  const maxV=rows[rows.length-1].total;
  rows.forEach(r=>{
    const h=Math.max(4,(r.total/maxV)*100);
    const col=document.createElement('div');col.className='mini-bar-col';
    col.title=`เดือน ${r.month}: ฿${fNum(r.total)}`;
    const bar=document.createElement('div');bar.className='mini-bar';
    bar.style.height=h+'%';
    col.appendChild(bar);barsEl.appendChild(col);
  });
  const res=document.getElementById('simple-result');
  res.style.display='block';res.classList.add('fadeUp');
}

// ═══ TAB 2: Portfolio ═══
let portfolioAssets=[];
let ptIdCounter=0;

function addPortfolioAsset(){
  const id=++ptIdCounter;
  const color=COLORS[(id-1)%COLORS.length];
  portfolioAssets.push({id,name:'',amount:'',growth:'',holdMonths:'',currentValue:'',color});
  renderPortfolio();
}

function removePortfolioAsset(id){
  portfolioAssets=portfolioAssets.filter(a=>a.id!==id);
  renderPortfolio();
}

function updatePortfolioAsset(id,field,val){
  const a=portfolioAssets.find(a=>a.id===id);
  if(a){a[field]=val;renderPortfolio();}
}

function computePortfolio(){
  return portfolioAssets.map(a=>{
    const amt=parseFloat(a.amount)||0;
    const g=parseFloat(a.growth)/100;
    const mo=parseInt(a.holdMonths)||0;
    const cur=parseFloat(a.currentValue);
    const value=(isNaN(cur)||a.currentValue==='')?amt*Math.pow(1+g/12,mo):cur;
    const gain=value-amt;
    const pct=amt>0?((gain/amt)*100).toFixed(1):'0.0';
    return{...a,value,gain,pct};
  });
}

function renderPortfolio(){
  const computed=computePortfolio();
  const totalInvested=computed.reduce((s,a)=>s+(parseFloat(a.amount)||0),0);
  const totalValue=computed.reduce((s,a)=>s+a.value,0);
  const totalGain=totalValue-totalInvested;

  if(totalInvested>0){
    document.getElementById('portfolio-summary').style.display='block';
    document.getElementById('pt-total').textContent=`฿${fNum(totalValue)}`;
    document.getElementById('pt-invested').textContent=`฿${fNum(totalInvested)}`;
    const gainEl=document.getElementById('pt-gain');
    gainEl.textContent=`${totalGain>=0?'+':''}฿${fNum(totalGain)}`;
    gainEl.style.color=totalGain>=0?'#22c55e':'#f43f5e';
  } else {
    document.getElementById('portfolio-summary').style.display='none';
  }

  // Donut
  if(totalValue>0){
    const wrap=document.getElementById('portfolio-donut-wrap');
    wrap.style.display='block';
    wrap.innerHTML=renderDonutSVG(computed,totalValue);
  }

  // Asset cards
  const container=document.getElementById('portfolio-assets');
  container.innerHTML='';
  computed.forEach((a,i)=>{
    const div=document.createElement('div');
    div.className='asset-row';
    div.style.borderLeft=`3px solid ${a.color}`;
    div.innerHTML=`
      <div style="display:flex;gap:10px;align-items:flex-start">
        <div style="flex:1">
          <div class="label">ชื่อทรัพย์สิน</div>
          <input class="inp" placeholder="เช่น SPUS, SCB…" value="${a.name}" style="color:${a.name?a.color:'#e2e8f0'};font-weight:700" oninput="updatePortfolioAsset(${a.id},'name',this.value)">
        </div>
        <button onclick="removePortfolioAsset(${a.id})" style="background:transparent;border:none;color:#334155;font-size:18px;cursor:pointer;margin-top:18px;border-radius:6px;padding:2px 6px">×</button>
      </div>
      <div class="asset-grid">
        <div><div class="label">ต้นทุน (฿)</div><input class="inp" type="number" placeholder="50000" value="${a.amount}" oninput="updatePortfolioAsset(${a.id},'amount',this.value)"></div>
        <div><div class="label">มูลค่าปัจจุบัน (฿)</div><input class="inp" type="number" placeholder="ว่าง = คำนวณ" value="${a.currentValue}" oninput="updatePortfolioAsset(${a.id},'currentValue',this.value)"></div>
        <div><div class="label">อัตราเติบโต/ปี (%)</div><input class="inp" type="number" placeholder="10" value="${a.growth}" oninput="updatePortfolioAsset(${a.id},'growth',this.value)"></div>
        <div><div class="label">ถือครอง (เดือน)</div><input class="inp" type="number" placeholder="24" value="${a.holdMonths}" oninput="updatePortfolioAsset(${a.id},'holdMonths',this.value)"></div>
      </div>
      ${parseFloat(a.amount)>0?`<div class="asset-val-bar"><span style="color:#94a3b8">มูลค่า: <b style="font-family:'DM Mono',monospace;color:#f59e0b">฿${fNum(a.value)}</b></span><span style="font-family:'DM Mono',monospace;color:${a.gain>=0?'#22c55e':'#f43f5e'}">${a.gain>=0?'▲':'▼'} ${a.pct}%</span></div>`:''}
    `;
    container.appendChild(div);
  });
}

function renderDonutSVG(assets,total){
  const filtered=assets.filter(a=>a.value>0);
  const cx=80,cy=80,r=60,sw=22,circ=2*Math.PI*r;
  let cum=0;
  const slices=filtered.map(a=>{
    const pct=a.value/total;
    const slice={...a,pct,dasharray:`${pct*circ} ${circ}`,dashoffset:-cum*circ};
    cum+=pct;return slice;
  });
  const displayVal=total>=1e6?`฿${(total/1e6).toFixed(2)}M`:total>=1e3?`฿${(total/1e3).toFixed(1)}K`:`฿${Math.round(total)}`;
  const svgCircles=slices.map(s=>`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${s.color}" stroke-width="${sw}" stroke-dasharray="${s.dasharray}" stroke-dashoffset="${s.dashoffset}" style="transform:rotate(-90deg);transform-origin:80px 80px"/>`).join('');
  const legend=slices.map(s=>`<div style="display:flex;align-items:center;gap:8px"><div style="width:8px;height:8px;border-radius:50%;background:${s.color};flex-shrink:0"></div><span style="font-size:12px;color:#e2e8f0;flex:1">${s.name||'ทรัพย์สิน'}</span><span style="font-family:'DM Mono',monospace;font-size:11px;color:#64748b">${(s.pct*100).toFixed(1)}%</span></div>`).join('');
  return`<div class="donut-wrap"><svg viewBox="0 0 160 160" style="width:120px;height:120px;flex-shrink:0"><circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#1a2035" stroke-width="${sw}"/>${svgCircles}<text x="${cx}" y="${cy-8}" text-anchor="middle" style="font-family:'DM Sans';font-size:9px;fill:#64748b">พอร์ตรวม</text><text x="${cx}" y="${cy+12}" text-anchor="middle" style="font-family:'DM Mono',monospace;font-size:11px;fill:#f59e0b;font-weight:bold">${displayVal}</text></svg><div style="flex:1;display:flex;flex-direction:column;gap:6px">${legend}</div></div>`;
}

// Init portfolio with one asset
addPortfolioAsset();

// ═══ TAB 3: Multi DCA ═══
let multiAssets=[
  {id:1,name:'SPUS',cagr:'15',alloc:'34',enabled:true,color:COLORS[0]},
  {id:2,name:'HLAL',cagr:'12',alloc:'33',enabled:true,color:COLORS[1]},
  {id:3,name:'TISCO',cagr:'10',alloc:'33',enabled:true,color:COLORS[2]},
];
let multiIdCounter=3;
let lineChartInstance=null;

function addMultiAsset(){
  multiIdCounter++;
  const color=COLORS[multiIdCounter%COLORS.length];
  multiAssets.push({id:multiIdCounter,name:'',cagr:'',alloc:'0',enabled:true,color});
  updateMulti();
}

function removeMultiAsset(id){
  multiAssets=multiAssets.filter(a=>a.id!==id);
  updateMulti();
}

function toggleMultiAsset(id){
  const a=multiAssets.find(a=>a.id===id);
  if(a){a.enabled=!a.enabled;updateMulti();}
}

function updateMultiField(id,field,val){
  const a=multiAssets.find(a=>a.id===id);
  if(a){a[field]=val;updateMulti();}
}

function autoBalance(){
  const enabled=multiAssets.filter(a=>a.enabled);
  const each=(100/enabled.length).toFixed(1);
  multiAssets.forEach(a=>{if(a.enabled)a.alloc=each;});
  updateMulti();
}

function updateMulti(){
  renderMultiRows();
  renderAllocDonut();
  const monthly=parseFloat(document.getElementById('m-monthly').value)||0;
  const years=parseInt(document.getElementById('m-years').value)||0;
  const ready=monthly>0&&years>0;
  const enabledAssets=multiAssets.filter(a=>a.enabled&&a.name&&parseFloat(a.cagr)>0&&parseFloat(a.alloc)>0);
  const totalAlloc=multiAssets.filter(a=>a.enabled).reduce((s,a)=>s+(parseFloat(a.alloc)||0),0);
  const allocOk=Math.abs(totalAlloc-100)<0.01;

  document.getElementById('multi-prompt').style.display=ready?'none':'block';
  const warn=document.getElementById('multi-alloc-warn');
  if(ready&&!allocOk&&totalAlloc>0){warn.style.display='block';document.getElementById('warn-alloc').textContent=totalAlloc.toFixed(1);}
  else warn.style.display='none';

  if(!ready||!enabledAssets.length){document.getElementById('multi-results').style.display='none';return;}

  // Compute chart data
  const chartData=[];
  for(let y=1;y<=years;y++) chartData.push({year:y,totalInvested:monthly*y*12,combined:0});
  enabledAssets.forEach(a=>{
    const share=(parseFloat(a.alloc)||0)/100;
    const m=monthly*share;
    calcDCA(m,years,parseFloat(a.cagr)).forEach(r=>{
      chartData[r.year-1][a.name]=r.portfolio;
      chartData[r.year-1].combined=(chartData[r.year-1].combined||0)+r.portfolio;
    });
  });

  // Summaries
  const summaries=enabledAssets.map(a=>{
    const share=(parseFloat(a.alloc)||0)/100;
    const m=monthly*share;
    const rows=calcDCA(m,years,parseFloat(a.cagr));
    const fin=rows[rows.length-1]?.portfolio??0;
    const inv=m*years*12;
    return{...a,monthlyAmount:m,final:fin,invested:inv,
      multiplier:inv>0?(fin/inv).toFixed(1):'—',
      hit1M:rows.find(r=>r.portfolio>=1e6)?.year??null,
      hit10M:rows.find(r=>r.portfolio>=1e7)?.year??null,
      hit100M:rows.find(r=>r.portfolio>=1e8)?.year??null};
  });

  const combinedFinal=summaries.reduce((s,a)=>s+a.final,0);
  const totalInvested=monthly*years*12;
  const mult=totalInvested>0?(combinedFinal/totalInvested).toFixed(1):'—';

  // Hero
  document.getElementById('multi-results').style.display='block';
  document.getElementById('hero-years').textContent=years;
  document.getElementById('hero-final').textContent=fBaht(combinedFinal);
  document.getElementById('hero-final-full').textContent=fFull(combinedFinal);
  document.getElementById('hero-invested').textContent=fBaht(totalInvested);
  document.getElementById('hero-mult').textContent=`${mult}x 🔥`;

  // Mini cards
  const miniGrid=document.getElementById('asset-mini-cards');
  miniGrid.innerHTML=summaries.map(a=>`
    <div class="asset-mini-card" style="background:${a.color}0d;border:1px solid ${a.color}28">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:13px;font-weight:800;color:${a.color};font-family:'DM Mono',monospace">${a.name}</span>
        <span style="font-size:11px;color:${a.color};background:${a.color}20;border-radius:5px;padding:1px 6px;font-family:'DM Mono',monospace">${a.alloc}%</span>
      </div>
      <div style="font-size:10px;color:#475569;font-family:'DM Mono',monospace;margin-top:2px">฿${Math.round(a.monthlyAmount).toLocaleString()}/เดือน</div>
      <div style="font-size:18px;font-weight:800;color:#e2e8f0;margin-top:6px">${fBaht(a.final)}</div>
      <div style="font-size:11px;color:#22c55e;margin-top:4px">${a.multiplier}x</div>
      <div style="font-size:10px;color:#64748b;margin-top:2px;font-family:'DM Mono',monospace">100M: ${a.hit100M?`ปีที่ ${a.hit100M}`:'—'}</div>
    </div>
  `).join('');

  // Chart
  renderLineChart(chartData,enabledAssets);

  // Table
  const step=Math.max(1,Math.floor(years/10));
  const tableRows=chartData.filter((_,i)=>(i+1)%step===0||i===chartData.length-1);
  const table=document.getElementById('data-table');
  const thCols=enabledAssets.map(a=>`<th style="color:${a.color}">${a.name}<br><span style="color:#475569;font-weight:400">${a.alloc}%</span></th>`).join('');
  table.innerHTML=`<thead><tr style="background:rgba(255,255,255,0.04)"><th style="text-align:left">ปี</th><th>ลงทุนไป</th>${thCols}<th style="color:#f59e0b">รวม</th></tr></thead>
  <tbody>${tableRows.map(row=>{
    const hit=(row.combined||0)>=1e8;
    const tdCols=enabledAssets.map(a=>`<td style="color:${a.color}">${fBaht(row[a.name]||0)}</td>`).join('');
    return`<tr style="${hit?'background:rgba(245,158,11,0.05)':''}"><td>${row.year}</td><td style="color:#475569">${fBaht(row.totalInvested)}</td>${tdCols}<td style="color:${hit?'#f59e0b':'#fff'};font-weight:${hit?800:600}">${fBaht(row.combined||0)}</td></tr>`;
  }).join('')}</tbody>`;

  // Milestone
  const c1M=chartData.find(r=>(r.combined||0)>=1e6)?.year??null;
  const c10M=chartData.find(r=>(r.combined||0)>=1e7)?.year??null;
  const c100M=chartData.find(r=>(r.combined||0)>=1e8)?.year??null;
  function msBadge(yr,color){
    if(!yr) return`<span style="font-size:11px;color:#334155">—</span>`;
    return`<div class="ms-badge" style="background:${color?color+'18':'rgba(245,158,11,0.15)'};border:1px solid ${color?color+'40':'rgba(245,158,11,0.4)'};color:${color||'#f59e0b'}">ปีที่ ${yr}</div>`;
  }
  const msContent=document.getElementById('milestone-content');
  msContent.innerHTML=`
    <div class="milestone-grid milestone-header"><span>ASSET</span><span style="text-align:center">฿1M</span><span style="text-align:center">฿10M</span><span style="text-align:center">฿100M</span></div>
    <div class="milestone-grid milestone-row" style="background:rgba(245,158,11,0.05)">
      <div><div style="font-weight:800;color:#f59e0b;font-family:'DM Mono',monospace;font-size:13px">🏆 รวม</div><div style="font-size:10px;color:#475569">ทั้งพอร์ต</div></div>
      <div style="text-align:center">${msBadge(c1M,null)}</div><div style="text-align:center">${msBadge(c10M,null)}</div><div style="text-align:center">${msBadge(c100M,null)}</div>
    </div>
    ${summaries.map(a=>`
    <div class="milestone-grid milestone-row">
      <div><div style="font-weight:800;color:${a.color};font-family:'DM Mono',monospace;font-size:13px">${a.name}</div><div style="font-size:10px;color:#475569">${a.alloc}% · ${a.cagr}%/ปี</div></div>
      <div style="text-align:center">${msBadge(a.hit1M,a.color)}</div><div style="text-align:center">${msBadge(a.hit10M,a.color)}</div><div style="text-align:center">${msBadge(a.hit100M,a.color)}</div>
    </div>`).join('')}
    <div style="padding:12px 16px;border-top:1px solid rgba(255,255,255,0.06);font-size:12px;color:#64748b;font-family:'DM Mono',monospace">
      ลงทุนรวม ${years} ปี = <span style="color:#f59e0b;font-weight:700">${fFull(totalInvested)}</span>
    </div>
  `;
}

function renderMultiRows(){
  const container=document.getElementById('multi-asset-rows');
  container.innerHTML=multiAssets.map(a=>`
    <div class="asset-row-multi">
      <button class="toggle-dot" style="color:${a.color};background:${a.enabled?a.color:'transparent'}" onclick="toggleMultiAsset(${a.id})"></button>
      <input class="inp" placeholder="NVDA…" value="${a.name}" style="opacity:${a.enabled?1:0.4};font-weight:700;color:${a.name?a.color:'#475569'}"
        oninput="updateMultiField(${a.id},'name',this.value.toUpperCase())">
      <input class="inp" type="number" placeholder="20" value="${a.cagr}" style="opacity:${a.enabled?1:0.4};text-align:center"
        oninput="updateMultiField(${a.id},'cagr',this.value)">
      <div style="position:relative">
        <input class="inp" type="number" placeholder="0" value="${a.alloc}" style="opacity:${a.enabled?1:0.4};text-align:center;padding-right:16px;${a.enabled&&parseFloat(a.alloc)>0?`border-color:${a.color}60`:''}"
          oninput="updateMultiField(${a.id},'alloc',this.value)">
        <span style="position:absolute;right:7px;top:50%;transform:translateY(-50%);font-size:10px;color:#475569;pointer-events:none">%</span>
      </div>
      <button class="btn-remove" onclick="removeMultiAsset(${a.id})">×</button>
    </div>
  `).join('');
}

function renderAllocDonut(){
  const active=multiAssets.filter(a=>a.enabled&&(parseFloat(a.alloc)||0)>0);
  const totalAlloc=multiAssets.filter(a=>a.enabled).reduce((s,a)=>s+(parseFloat(a.alloc)||0),0);
  const allocColor=totalAlloc>100?'#f43f5e':totalAlloc===0?'#475569':totalAlloc<100?'#f59e0b':'#22c55e';
  const monthly=parseFloat(document.getElementById('m-monthly').value)||0;
  const cx=72,cy=72,r=54,sw=20,circ=2*Math.PI*r;
  let cum=0;
  const slices=active.map(a=>{
    const pct=Math.min((parseFloat(a.alloc)||0)/100,1);
    const slice={...a,pct,dasharray:`${pct*circ} ${circ}`,dashoffset:-cum*circ};
    cum+=pct;return slice;
  });
  const svgSlices=slices.map(s=>`<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${s.color}" stroke-width="${sw}" stroke-dasharray="${s.dasharray}" stroke-dashoffset="${s.dashoffset}" style="transform:rotate(-90deg);transform-origin:${cx}px ${cy}px;transition:stroke-dasharray 0.3s"/>`).join('');
  const legend=slices.map(s=>`
    <div style="display:flex;align-items:center;gap:8px">
      <div style="width:10px;height:10px;border-radius:50%;background:${s.color};flex-shrink:0;box-shadow:0 0 6px ${s.color}80"></div>
      <span style="font-size:12px;font-weight:700;color:${s.color};font-family:'DM Mono',monospace;flex:1">${s.name||'?'}</span>
      <span style="font-size:12px;color:#94a3b8;font-family:'DM Mono',monospace">${s.alloc}%</span>
    </div>
    ${monthly>0?`<div style="font-size:10px;color:${s.color};font-family:'DM Mono',monospace;display:flex;justify-content:space-between;padding-left:18px"><span>${s.name||'?'}</span><span style="color:#64748b">฿${Math.round(monthly*(parseFloat(s.alloc)||0)/100).toLocaleString()}/เดือน</span></div>`:''}
  `).join('');

  const wrap=document.getElementById('alloc-donut-wrap');
  wrap.style.borderColor=`${allocColor}30`;
  wrap.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
      <span style="font-size:11px;color:#64748b;font-family:'DM Mono',monospace">สัดส่วนพอร์ต</span>
      <span style="font-size:12px;font-weight:800;color:${allocColor};font-family:'DM Mono',monospace">
        ${totalAlloc.toFixed(1)}% ${totalAlloc===100?'✅':totalAlloc>100?'⚠️ เกิน':`(เหลือ ${(100-totalAlloc).toFixed(1)}%)`}
      </span>
    </div>
    <div style="display:flex;align-items:center;gap:16px">
      <svg viewBox="0 0 144 144" style="width:110px;height:110px;flex-shrink:0">
        <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="${sw}"/>
        ${svgSlices}
        <text x="${cx}" y="${cy-7}" text-anchor="middle" style="font-size:9px;fill:#64748b;font-family:'DM Mono',monospace">สัดส่วน</text>
        <text x="${cx}" y="${cy+10}" text-anchor="middle" style="font-size:14px;font-weight:bold;fill:${totalAlloc===100?'#22c55e':allocColor};font-family:'DM Mono',monospace">${totalAlloc.toFixed(0)}%</text>
      </svg>
      <div style="flex:1;display:flex;flex-direction:column;gap:7px">${legend}</div>
    </div>
  `;
}

function renderLineChart(chartData,enabledAssets){
  const legend=document.getElementById('chart-legend');
  legend.innerHTML=enabledAssets.map(a=>`<div style="font-size:10px;color:${a.color};font-family:'DM Mono',monospace;display:flex;align-items:center;gap:4px"><div style="width:16px;height:2px;background:${a.color}"></div>${a.name} (${a.alloc}%)</div>`).join('');

  const labels=chartData.map(d=>d.year);
  const datasets=[
    {label:'ลงทุนไป',data:chartData.map(d=>d.totalInvested),borderColor:'#1e293b',borderWidth:1.5,borderDash:[4,4],pointRadius:0,fill:false},
    {label:'รวม',data:chartData.map(d=>d.combined),borderColor:'rgba(255,255,255,0.5)',borderWidth:2.5,pointRadius:0,fill:false},
    ...enabledAssets.map(a=>({label:a.name,data:chartData.map(d=>d[a.name]||0),borderColor:a.color,borderWidth:2,pointRadius:0,fill:false}))
  ];

  const ctx=document.getElementById('lineChart');
  if(lineChartInstance){lineChartInstance.destroy();}
  lineChartInstance=new Chart(ctx,{
    type:'line',
    data:{labels,datasets},
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{
          backgroundColor:'rgba(8,10,18,0.97)',borderColor:'rgba(255,255,255,0.1)',borderWidth:1,
          titleColor:'#f59e0b',bodyColor:'#e2e8f0',
          callbacks:{
            title:ctx=>`ปีที่ ${ctx[0].label}`,
            label:ctx=>`${ctx.dataset.label}: ${fBaht(ctx.raw)}`
          }
        },
        annotation:{annotations:{line100M:{type:'line',yMin:1e8,yMax:1e8,borderColor:'#f59e0b',borderDash:[4,4],borderWidth:1,label:{content:'100M',enabled:true,color:'#f59e0b',font:{size:10}}}}}
      },
      scales:{
        x:{ticks:{color:'#475569',font:{size:11}},grid:{color:'rgba(255,255,255,0.05)'},title:{display:true,text:'ปี',color:'#475569',font:{size:11}}},
        y:{ticks:{color:'#475569',font:{size:10},callback:v=>fBaht(v)},grid:{color:'rgba(255,255,255,0.05)'}}
      }
    }
  });
}

// Init multi
renderMultiRows();
renderAllocDonut();
</script>
