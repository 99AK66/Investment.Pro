<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Investment Planner — วางแผนการลงทุน</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;700;800&family=DM+Mono:wght@400;700&display=swap">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  body{min-height:100vh;background:#07090f;color:#e2e8f0;font-family:'DM Sans',sans-serif;padding-bottom:56px;}
  input::placeholder{color:#334155;}
  input:focus{border-color:rgba(245,158,11,0.5)!important;box-shadow:0 0 0 2px rgba(245,158,11,0.1)!important;outline:none;}
  input[type=number]::-webkit-inner-spin-button{opacity:0.3;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
  .fadeUp{animation:fadeUp 0.3s ease;}

  /* Layout */
  .header{background:linear-gradient(135deg,#0f1629,#0a0e1a);border-bottom:1px solid rgba(245,158,11,0.15);padding:22px 20px 16px;text-align:center;}
  .header-sup{font-size:10px;letter-spacing:4px;color:#f59e0b;font-family:'DM Mono',monospace;margin-bottom:6px;}
  .header-title{font-size:22px;font-weight:800;letter-spacing:-0.5px;}
  .header-sub{font-size:11px;color:#475569;margin-top:4px;font-family:'DM Mono',monospace;}
  .accent{color:#f59e0b;}

  /* Tab bar */
  .tab-bar{display:flex;gap:0;margin:16px 16px 0;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:4px;}
  .tab-btn{flex:1;padding:10px 4px;border:none;background:transparent;border-radius:9px;color:#475569;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.18s;}
  .tab-btn.active{background:rgba(245,158,11,0.12);color:#f59e0b;outline:1px solid rgba(245,158,11,0.3);}
  .tab-btn .tab-desc{font-size:9px;font-family:'DM Mono',monospace;opacity:0.7;margin-top:2px;}
  .tab-content{display:none;padding:0 16px;}
  .tab-content.active{display:block;}

  /* Inputs */
  .inp{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:10px 12px;color:#e2e8f0;font-size:13px;font-family:'DM Mono',monospace;width:100%;}
  .label{font-size:10px;color:#64748b;margin-bottom:6px;font-family:'DM Mono',monospace;letter-spacing:1px;}

  /* Cards / panels */
  .panel{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:16px;margin-top:16px;}
  .panel-title{font-size:11px;color:#64748b;letter-spacing:2px;font-family:'DM Mono',monospace;margin-bottom:14px;}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

  /* Button */
  .btn-primary{width:100%;padding:13px;background:#f59e0b;border:none;border-radius:10px;color:#000;font-weight:800;font-size:15px;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:14px;}
  .btn-dashed{width:100%;padding:12px;background:transparent;color:#3b82f6;border:1.5px dashed rgba(59,130,246,0.5);border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:14px;}

  /* Result cards */
  .result-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
  .result-card{background:rgba(0,0,0,0.3);border-radius:9px;padding:10px 8px;text-align:center;border:1px solid rgba(255,255,255,0.06);}
  .result-label{font-size:10px;color:#64748b;margin-bottom:5px;font-family:'DM Mono',monospace;}
  .result-val{font-family:'DM Mono',monospace;font-size:11px;font-weight:700;}

  /* Asset row */
  .asset-row{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:14px;margin-bottom:12px;}
  .asset-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px;}
  .asset-val-bar{display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.3);border-radius:8px;padding:8px 12px;margin-top:10px;font-size:13px;border:1px solid rgba(255,255,255,0.06);}

  /* Mini bar chart */
  .mini-bar-wrap{display:flex;align-items:flex-end;gap:2px;height:60px;margin-top:16px;}
  .mini-bar-col{flex:1;height:100%;display:flex;align-items:flex-end;}
  .mini-bar{width:100%;background:linear-gradient(to top,#3b82f6,#f59e0b);border-radius:2px 2px 0 0;opacity:0.85;min-height:4px;}
  .mini-bar-labels{display:flex;justify-content:space-between;font-size:10px;color:#475569;margin-top:4px;font-family:'DM Mono',monospace;}

  /* Multi DCA */
  .multi-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
  .btn-auto{background:transparent;border:1px solid rgba(255,255,255,0.1);border-radius:7px;padding:5px 12px;color:#94a3b8;font-weight:600;cursor:pointer;font-size:11px;font-family:'DM Mono',monospace;}
  .btn-add{background:#f59e0b;border:none;border-radius:7px;padding:5px 14px;color:#000;font-weight:800;cursor:pointer;font-size:13px;}
  .asset-cols-header{display:grid;grid-template-columns:24px 1fr 80px 72px 32px;gap:8px;padding:0 4px 8px;font-size:10px;color:#475569;font-family:'DM Mono',monospace;letter-spacing:1px;border-bottom:1px solid rgba(255,255,255,0.06);}
  .asset-row-multi{display:grid;grid-template-columns:24px 1fr 80px 72px 32px;gap:8px;align-items:center;margin-top:8px;}
  .toggle-dot{width:18px;height:18px;border-radius:4px;border:2px solid currentColor;cursor:pointer;flex-shrink:0;}
  .btn-remove{background:transparent;border:none;color:#334155;cursor:pointer;font-size:20px;line-height:1;}

  /* Summary hero */
  .summary-hero{background:linear-gradient(135deg,rgba(245,158,11,0.12),rgba(245,158,11,0.04));border:1px solid rgba(245,158,11,0.3);border-radius:14px;padding:14px 16px;margin-top:14px;display:flex;justify-content:space-between;align-items:center;}

  /* Asset mini-cards */
  .asset-mini-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-top:10px;}
  .asset-mini-card{border-radius:12px;padding:12px;}

  /* Sub-tabs */
  .sub-tabs{display:flex;gap:4px;margin-top:14px;}
  .sub-tab-btn{flex:1;padding:9px 4px;border-radius:8px;border:1px solid rgba(255,255,255,0.07);background:transparent;color:#64748b;font-size:12px;font-weight:700;cursor:pointer;font-family:'DM Mono',monospace;}
  .sub-tab-btn.active{border-color:#f59e0b;background:rgba(245,158,11,0.1);color:#f59e0b;}
  .sub-tab-content{display:none;}
  .sub-tab-content.active{display:block;}

  /* Chart wrapper */
  .chart-wrap{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:18px 6px 12px;margin-top:10px;}
  canvas{max-height:270px;}

  /* Table */
  .data-table{width:100%;border-collapse:collapse;font-family:'DM Mono',monospace;font-size:12px;}
  .data-table th{padding:10px 12px;text-align:right;font-size:11px;color:#64748b;background:rgba(255,255,255,0.04);}
  .data-table th:first-child{text-align:left;}
  .data-table td{padding:9px 12px;text-align:right;border-top:1px solid rgba(255,255,255,0.05);}
  .data-table td:first-child{text-align:left;color:#94a3b8;}

  /* Milestone */
  .milestone-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;}
  .milestone-header{background:rgba(255,255,255,0.04);padding:10px 14px;font-size:11px;color:#64748b;font-family:'DM Mono',monospace;}
  .milestone-row{padding:12px 14px;border-top:1px solid rgba(255,255,255,0.05);align-items:center;}
  .ms-badge{display:inline-block;border-radius:8px;padding:4px 10px;font-size:12px;font-weight:700;font-family:'DM Mono',monospace;}

  /* Donut SVG */
  .donut-wrap{display:flex;align-items:center;gap:16px;margin-bottom:16px;padding:12px;background:rgba(255,255,255,0.03);border-radius:12px;border:1px solid rgba(255,255,255,0.07);}
  .alloc-panel{margin-top:12px;background:rgba(255,255,255,0.03);border-radius:12px;padding:14px 12px;}

  .warning{margin-top:10px;padding:12px 16px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);border-radius:12px;font-size:12px;color:#f59e0b;font-family:'DM Mono',monospace;text-align:center;}
  .footer-note{text-align:center;font-size:10px;color:#1e293b;margin-top:24px;padding:0 16px;line-height:1.8;}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-sup">INVESTMENT PLANNER</div>
  <div class="header-title">วางแผน<span class="accent">การลงทุน</span></div>
  <div class="header-sub">DCA · Portfolio Tracker · Multi-Asset Simulator</div>
</div>

<!-- MAIN TABS -->
<div class="tab-bar">
  <button class="tab-btn active" onclick="switchTab('simple',this)">
    📈 DCA<div class="tab-desc">คำนวณรายตัว</div>
  </button>
  <button class="tab-btn" onclick="switchTab('portfolio',this)">
    💼 พอร์ต<div class="tab-desc">ติดตามทรัพย์สิน</div>
  </button>
  <button class="tab-btn" onclick="switchTab('multi',this)">
    🔀 Multi<div class="tab-desc">จัดพอร์ต DCA</div>
  </button>
</div>

<!-- ═══ TAB 1: Simple DCA ═══ -->
<div id="tab-simple" class="tab-content active">
  <div class="panel">
    <div class="panel-title">SIMPLE DCA CALC</div>
    <div class="grid-2">
      <div><div class="label">ชื่อทรัพย์สิน</div><input class="inp" id="s-name" type="text" placeholder="เช่น CPALL, KBANK…"></div>
      <div><div class="label">DCA ต่อเดือน (฿)</div><input class="inp" id="s-monthly" type="number" placeholder="5000"></div>
      <div><div class="label">ระยะเวลา (เดือน)</div><input class="inp" id="s-months" type="number" placeholder="120"></div>
      <div><div class="label">ผลตอบแทนต่อปี (%)</div><input class="inp" id="s-growth" type="number" placeholder="7"></div>
    </div>
    <button class="btn-primary" onclick="calcSimple()">คำนวณ →</button>
  </div>
  <div id="simple-result" style="display:none" class="fadeUp">
    <div class="panel" style="margin-top:14px;">
      <div id="s-asset-name" style="font-size:15px;font-weight:800;color:#f59e0b;margin-bottom:14px;font-family:'DM Mono',monospace;"></div>
      <div class="result-grid">
        <div class="result-card"><div class="result-label">ลงทุนไป</div><div class="result-val" id="s-invested" style="color:#3b82f6"></div></div>
        <div class="result-card"><div class="result-label">มูลค่าสุดท้าย</div><div class="result-val" id="s-final" style="color:#f59e0b"></div></div>
        <div class="result-card"><div class="result-label">กำไรรวม</div><div class="result-val" id="s-gain"></div></div>
      </div>
      <div class="mini-bar-wrap" id="s-bars"></div>
      <div class="mini-bar-labels"><span>เดือน 1</span><span id="s-month-end">เดือน 120</span></div>
    </div>
